:{"id":"5p3T-ucpx5Ze","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776919177842,"user_tz":-330,"elapsed":39591,"user":{"displayName":"rahil qureshi","userId":"00739294798719978627"}},"outputId":"6df36fff-3045-4728-a651-f13b59e9d64d","trusted":true,"execution":{"iopub.status.busy":"2026-04-23T08:53:35.117788Z","iopub.execute_input":"2026-04-23T08:53:35.118388Z","iopub.status.idle":"2026-04-23T08:53:35.468019Z","shell.execute_reply.started":"2026-04-23T08:53:35.118359Z","shell.execute_reply":"2026-04-23T08:53:35.467355Z"}},"outputs":[{"name":"stdout","text":"Original image batch shape: (32, 256, 256, 3)\nOriginal pixel range: 0.0 to 255.0\nOriginal label batch shape: (32, 4)\n","output_type":"stream"}],"execution_count":15},{"cell_type":"markdown","source":"# Custom CNN model\n\nBuilding a baseline CNN Architecture with some Convolutional blocks which MaxPooling\n","metadata":{"id":"_MNAjuQCNi4H"}},{"cell_type":"code","source":"AUTOTUNE = tf.data.AUTOTUNE\n\ntrain_ds = train_ds.map(lambda x, y: (tf.cast(x, tf.float32)/255.0, y)).cache().shuffle(1000).prefetch(buffer_size=AUTOTUNE)\nval_ds   = val_ds.map(lambda x, y: (tf.cast(x, tf.float32)/255.0, y)).cache().prefetch(buffer_size=AUTOTUNE)\ntest_ds  = test_ds.map(lambda x, y: (tf.cast(x, tf.float32)/255.0, y)).cache().prefetch(buffer_size=AUTOTUNE)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-23T08:53:38.922421Z","iopub.execute_input":"2026-04-23T08:53:38.923266Z","iopub.status.idle":"2026-04-23T08:53:38.997171Z","shell.execute_reply.started":"2026-04-23T08:53:38.923236Z","shell.execute_reply":"2026-04-23T08:53:38.996599Z"}},"outputs":[],"execution_count":16},{"cell_type":"code","source":"model = tf.keras.Sequential([\n    # Remove this if you already normalized in dataset pipeline\n    # tf.keras.layers.Rescaling(1./255, input_shape=[image_size[0], image_size[1], 3]),\n\n    tf.keras.layers.Conv2D(filters=32, kernel_size=3, padding='same', activa